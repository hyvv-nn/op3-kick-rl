<!-- op3_kick_scene.xml  v2 [샌드박스 검증완료 2026-06-15]
     ★ mujoco_menagerie/robotis_op3/ 폴더 안에 둘 것. 고정베이스는 env 코드 핀(weld 아님).
     공 = 현실값(반지름 0.07m, 질량 0.15kg). env.reset()이 차는 발 앞 offset 0.15로 재배치(겹침 방지). -->
<mujoco model="op3_kick">
  <include file="op3.xml"/>
  <option timestep="0.005" iterations="50" solver="Newton"/>
  <statistic center="0 0 0.2" extent="1.2"/>
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <global azimuth="120" elevation="-20"/>
  </visual>
  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom name="floor" type="plane" size="5 5 0.1" pos="0 0 0"
          friction="1 0.005 0.0001" rgba="0.4 0.5 0.4 1"/>
    <body name="ball" pos="0.18 -0.07 0.07">
      <!-- 현실값: RoboCup 키즈사이즈급(반지름 0.07m, 질량 0.15kg). ★정확 규격은 확인 권장 -->
      <freejoint name="ball_free"/>
      <geom name="ball_geom" type="sphere" size="0.07" mass="0.15"
            friction="0.8 0.01 0.0001" rgba="0.9 0.6 0.1 1"/>
    </body>
    <site name="target" pos="1.2 -0.07 0.07" size="0.05" rgba="1 0 0 0.5"/>
    <!-- ★ 시각 골대 (A방식: contype=0 conaffinity=0 → 물리 간섭 0, 순수 시각). 골라인 x=1.5, 골폭 1.2m, 높이 0.8m -->
    <body name="goal" pos="0 0 0">
      <!-- 왼 기둥 -->
      <geom name="goal_post_l" type="capsule" fromto="1.5 0.53 0  1.5 0.53 0.8"
            size="0.025" contype="0" conaffinity="0" rgba="0.95 0.95 0.95 1"/>
      <!-- 오른 기둥 -->
      <geom name="goal_post_r" type="capsule" fromto="1.5 -0.67 0  1.5 -0.67 0.8"
            size="0.025" contype="0" conaffinity="0" rgba="0.95 0.95 0.95 1"/>
      <!-- 크로스바 -->
      <geom name="goal_crossbar" type="capsule" fromto="1.5 0.53 0.8  1.5 -0.67 0.8"
            size="0.025" contype="0" conaffinity="0" rgba="0.95 0.95 0.95 1"/>
    </body>
  </worldbody>
</mujoco>
