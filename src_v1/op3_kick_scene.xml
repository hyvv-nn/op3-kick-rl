<!-- op3_kick_scene.xml  v1 [초기 버전 — 가벼운 공 0.05kg. 정식은 상위 폴더 v2]
     ★ mujoco_menagerie/robotis_op3/ 폴더 안에 둘 것. 고정베이스는 env 코드 핀(weld 아님). -->
<mujoco model="op3_kick">
  <include file="op3.xml"/>
  <option timestep="0.005" iterations="50" solver="Newton"/>
  <statistic center="0 0 0.2" extent="1.2"/>
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <global azimuth="120" elevation="-20"/>
  </visual>
  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom name="floor" type="plane" size="5 5 0.1" pos="0 0 0"
          friction="1 0.005 0.0001" rgba="0.4 0.5 0.4 1"/>
    <body name="ball" pos="0.18 -0.07 0.05">
      <freejoint name="ball_free"/>
      <geom name="ball_geom" type="sphere" size="0.05" mass="0.05"
            friction="0.6 0.005 0.0001" rgba="0.9 0.6 0.1 1"/>
    </body>
    <site name="target" pos="1.2 -0.07 0.05" size="0.05" rgba="1 0 0 0.5"/>
  </worldbody>
</mujoco>
